APP_NAME=PosSelection
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=stderr,graylog
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

GRAYLOG_HOST=graylog
GRAYLOG_PORT=12201
GRAYLOG_LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=pos_selection
DB_USERNAME=pos_user
DB_PASSWORD=secret
DB_ROOT_PASSWORD=secret

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=
REDIS_PORT=6379

# Docker forwarded ports (host → container)
FORWARD_NGINX_PORT=8080
FORWARD_MYSQL_PORT=3307
FORWARD_REDIS_PORT=6380
FORWARD_GRAYLOG_PORT=9000
FORWARD_GRAYLOG_GELF_PORT=12201
OPENSEARCH_INITIAL_ADMIN_PASSWORD=Op3nS3arch!2026
GRAYLOG_PASSWORD_SECRET=somepasswordpepper1234567890abcdef
GRAYLOG_ROOT_PASSWORD_SHA2=8c6976e5b5410415bde908bd4dee15dfb167a9c873fc4bb8a81f6f2ab448a918

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

HORIZON_PREFIX=pos-horizon:

VITE_APP_NAME="${APP_NAME}"
